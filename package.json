{
  "name": "foodbridge-backend",
  "version": "1.0.0",
  "description": "FoodBridge AI Platform Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "seed": "node -e \"require('./dist/seeds/seedDiningHall.js').seedDiningHall().then(() => process.exit(0)).catch(() => process.exit(1))\"",
    "seed:students": "node -e \"require('./dist/seeds/seedStudents.js').seedStudents().then(() => process.exit(0)).catch(() => process.exit(1))\"",
    "seed:pantry": "node -e \"require('./dist/seeds/seedPantryInventory.js').seedPantryInventory().then(() => process.exit(0)).catch(() => process.exit(1))\"",
    "seed:events": "node -e \"require('./dist/seeds/seedEvents.js').seedEvents().then(() => process.exit(0)).catch(() => process.exit(1))\""
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    },
    "testMatch": [
      "**/*.test.ts",
      "**/*.properties.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  },
  "keywords": [
    "foodbridge",
    "api",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "heroku": "^11.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.104.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "winston": "^3.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^8.2.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.0",
    "@types/winston": "^2.4.4",
    "fast-check": "^4.6.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
